# EC2 Docker Compose profile.
# Copy to .env.server on the server and replace every placeholder.

POS_ENV_FILE=.env.server
POS_APP_PORT=8080

POS_DB_NAME=pos_mk1
POS_DB_USERNAME=pos
POS_DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POS_DB_BIND=127.0.0.1
POS_DB_PORT=5432
POS_DB_TZ=Asia/Seoul

POS_DB_URL=jdbc:postgresql://postgres:5432/pos_mk1
POS_REDIS_HOST=redis
POS_REDIS_BIND=127.0.0.1
POS_REDIS_PORT=6379
POS_REDIS_PASSWORD=
POS_REDIS_NAMESPACE=pos:mk1:session
POS_NOTE_LIST_CACHE_KEY_PREFIX=pos:mk1:notes:list:v1:
POS_NOTE_LIST_CACHE_TTL=PT5M

POS_ELASTICSEARCH_URIS=http://elasticsearch:9200
POS_ELASTICSEARCH_BIND=127.0.0.1
POS_ELASTICSEARCH_PORT=9200
POS_SEARCH_ELASTICSEARCH_ENABLED=false
POS_SEARCH_ELASTICSEARCH_INDEX_NAME=notes-mk1
POS_SEARCH_ELASTICSEARCH_REINDEX_ON_STARTUP=true

POS_SECURITY_USERNAME=admin@gmail.com
POS_SECURITY_PASSWORD=admin123!@#
POS_SECURITY_ROLE=ROLE_USER
POS_JWT_SECRET=CHANGE_ME_AT_LEAST_32_BYTES

POS_AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_MAX_OUTPUT_TOKENS=4096
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
