# Copy this file to .env and edit values for your local machine.
# .env is ignored by Git to avoid leaking secrets.
#
# ⚠️  주의: Docker Compose와 Spring Boot가 같은 비밀번호를 사용해야 합니다.
#    아래 POS_DB_PASSWORD 값을 바꾸면 두 곳 모두에 적용됩니다.
#    로컬 개발용이므로 간단한 값을 사용합니다 (실서버에서는 반드시 강한 비밀번호로 변경).

# Spring Boot datasource (used by src/main/resources/application.yaml)
POS_DB_URL=jdbc:postgresql://localhost:5432/personal_operating_system
POS_DB_USERNAME=pos
POS_DB_PASSWORD=pos


# Docker Compose PostgreSQL container setup (used by compose.yaml)
POS_DB_NAME=personal_operating_system
POS_DB_TZ=Asia/Seoul

# Redis session store (used by src/main/resources/application.yaml)
POS_REDIS_HOST=localhost
POS_REDIS_PORT=6379
POS_REDIS_PASSWORD=

# Elasticsearch search (used by src/main/resources/application.yaml)
POS_ELASTICSEARCH_URIS=http://localhost:9200
POS_SEARCH_ELASTICSEARCH_ENABLED=false
POS_SEARCH_ELASTICSEARCH_INDEX_NAME=notes-v1
POS_SEARCH_ELASTICSEARCH_REINDEX_ON_STARTUP=true

# AI provider / API key (used by src/main/resources/application.yaml)
POS_AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro



